# ==========================================
# FRONTEND VERCEL ENVIRONMENT VARIABLES
# ==========================================

# ─── API Configuration ────────────────────
# The base URL of your backend.
# Local Development: http://localhost:5000/api
# Production (Render): https://vixora-backend-ysg8.onrender.com/api
VITE_API_URL=https://vixora-backend-ysg8.onrender.com/api

# ─── Google OAuth Configuration ───────────
# Required for Google Sign-In functionality on the frontend UI.
# Get your Client ID from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
